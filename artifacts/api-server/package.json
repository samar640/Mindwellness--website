    "express-session": "^1.18.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/express-session": "^1.18.2",
    "@types/node": "^24.0.0",
    "cross-env": "^7.0.3",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3"
  }
